{
   "action": {
      "default_icon": {
         "128": "logo-128x128.png",
         "16": "logo-16x16.png",
         "32": "logo-32x32.png",
         "48": "logo-48x48.png",
         "64": "logo-64x64.png"
      },
      "default_title": "Merlin AI"
   },
   "author": {
      "email": "support@foyer.work"
   },
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "_execute_action": {
         "description": "Open Merlin AI",
         "suggested_key": {
            "default": "Ctrl+M",
            "mac": "Command+M"
         }
      }
   },
   "content_scripts": [ {
      "js": [ "content-scripts/blog-summarizer.js", "content-scripts/floatingCTA.js", "content-scripts/giveFreely.js", "content-scripts/main.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content-scripts/gmailStrip.js" ],
      "matches": [ "https://mail.google.com/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content-scripts/linkedinStrip.js" ],
      "matches": [ "https://www.linkedin.com/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content-scripts/twitterStrip.js" ],
      "matches": [ "https://twitter.com/*", "https://x.com/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content-scripts/youtube-pot.js" ],
      "matches": [ "*://*.youtube.com/*" ],
      "run_at": "document_start",
      "world": "MAIN"
   }, {
      "js": [ "content-scripts/youtube.js" ],
      "matches": [ "*://*.youtube.com/*" ],
      "run_at": "document_idle"
   } ],
   "default_locale": "en",
   "description": "__MSG_extensionDescription__",
   "externally_connectable": {
      "matches": [ "*://*.getmerlin.in/*", "*://*.foyer.work/*" ]
   },
   "host_permissions": [ "https://*/*" ],
   "icons": {
      "128": "logo-128x128.png",
      "16": "logo-16x16.png",
      "32": "logo-32x32.png",
      "48": "logo-48x48.png",
      "64": "logo-64x64.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_extensionName__",
   "optional_host_permissions": [ "\u003Call_urls>" ],
   "optional_permissions": [ "identity" ],
   "permissions": [ "sidePanel", "storage", "contextMenus", "tabs", "alarms", "webNavigation", "webRequest", "scripting" ],
   "side_panel": {
      "default_path": "sidepanel.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "8.0.11",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "logo-64x64.png" ]
   }, {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "content-scripts/blog-summarizer.css" ],
      "use_dynamic_url": true
   }, {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "content-scripts/floatingCTA.css" ],
      "use_dynamic_url": true
   }, {
      "matches": [ "https://www.linkedin.com/*" ],
      "resources": [ "content-scripts/linkedinStrip.css" ],
      "use_dynamic_url": true
   }, {
      "matches": [ "https://twitter.com/*", "https://x.com/*" ],
      "resources": [ "content-scripts/twitterStrip.css" ],
      "use_dynamic_url": true
   }, {
      "matches": [ "*://*.youtube.com/*" ],
      "resources": [ "content-scripts/youtube.css" ],
      "use_dynamic_url": true
   } ]
}
